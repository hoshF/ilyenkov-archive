{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Philosopher Glossary",
  "type": "object",
  "required": [
    "schema_version",
    "author_id",
    "updated_at",
    "source_corpus_paths",
    "required_entry_ids",
    "entries"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": 1
    },
    "author_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "updated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "source_corpus_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "required_entry_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "canonical",
          "forms",
          "zh_preferred",
          "zh_alternatives",
          "status",
          "notes",
          "evidence"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "category": {
            "enum": ["person", "work", "concept", "institution", "journal"]
          },
          "canonical": {
            "type": "string",
            "minLength": 1
          },
          "forms": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "zh_preferred": {
            "type": "string",
            "minLength": 1
          },
          "zh_alternatives": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "enum": ["approved", "provisional", "needs_review"]
          },
          "notes": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["corpus_path", "note"],
              "additionalProperties": false,
              "properties": {
                "corpus_path": {
                  "type": "string"
                },
                "note": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
